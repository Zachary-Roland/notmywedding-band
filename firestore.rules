rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /links/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shows/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /videos/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
